diff --git a/assets/css/style.css b/assets/css/style.css
index e69de29..84a0d97 100644
--- a/assets/css/style.css
+++ b/assets/css/style.css
@@ -0,0 +1,436 @@
+:root {
+  --paper: #fff;
+  --ink: #111;
+  --muted: #6f6f6f;
+  --line: #d7d7d7;
+  --soft: #f3f3f3;
+  --red: #b11226;
+  --focus: #b11226;
+  --title-font: "Shippori Mincho", "Times New Roman", serif;
+  --ui-font: "IBM Plex Mono", "Courier New", monospace;
+  --accent-font: "DotGothic16", "IBM Plex Mono", monospace;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html,
+body {
+  cursor: auto;
+}
+
+html {
+  background: var(--paper);
+  color: var(--ink);
+  font-family: var(--ui-font);
+  font-size: 16px;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+}
+
+body.intro-active {
+  overflow: hidden;
+}
+
+body.overlay-open {
+  overflow: hidden;
+}
+
+a {
+  color: inherit;
+  text-decoration-color: var(--red);
+  text-decoration-thickness: 1px;
+  text-underline-offset: 0.18em;
+}
+
+a,
+button,
+.card-button,
+[role="button"] {
+  cursor: pointer;
+}
+
+button,
+video {
+  font: inherit;
+}
+
+button {
+  color: inherit;
+}
+
+:focus-visible {
+  outline: 2px solid var(--focus);
+  outline-offset: 4px;
+}
+
+.visually-hidden {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+.skip-link {
+  position: fixed;
+  left: 1rem;
+  top: 1rem;
+  z-index: 10000;
+  padding: 0.65rem 0.85rem;
+  background: var(--paper);
+  border: 1px solid var(--ink);
+  transform: translateY(-180%);
+}
+
+.skip-link:focus {
+  transform: translateY(0);
+}
+
+#intro-screen {
+  position: fixed;
+  inset: 0;
+  z-index: 9999;
+  display: grid;
+  place-items: center;
+  padding: 1.5rem;
+  background: var(--paper);
+  color: var(--ink);
+  opacity: 1;
+  visibility: visible;
+  pointer-events: auto;
+  cursor: pointer;
+  transition: opacity 1200ms ease;
+}
+
+#intro-screen.intro-dismissing {
+  opacity: 0;
+  pointer-events: none;
+}
+
+#intro-screen[hidden],
+.video-overlay[hidden] {
+  display: none !important;
+}
+
+#intro-screen blockquote {
+  margin: 0;
+}
+
+#intro-screen p {
+  max-width: 18rem;
+  margin: 0;
+  color: var(--muted);
+  font-family: var(--title-font);
+  font-size: clamp(1.25rem, 4vw, 2.2rem);
+  line-height: 1.35;
+  text-align: center;
+}
+
+.site-header {
+  display: grid;
+  place-items: center;
+  gap: 1rem;
+  padding: 2rem 1.25rem 2.5rem;
+  text-align: center;
+  background: transparent;
+}
+
+.site-title,
+.site-title:focus,
+.site-title:active,
+.site-title:focus-visible,
+.site-header h1,
+.site-header h1:focus,
+.site-header h1:active,
+.site-header h1:focus-visible {
+  color: var(--ink);
+  background: transparent;
+}
+
+.site-title {
+  margin: 0;
+  font-family: var(--title-font);
+  font-size: clamp(4.4rem, 16vw, 12rem);
+  font-weight: 500;
+  line-height: 0.9;
+  letter-spacing: 0;
+  text-transform: none;
+}
+
+.site-title:focus,
+.site-title:focus-visible {
+  outline: 1px solid var(--focus);
+  outline-offset: 0.35rem;
+}
+
+.site-header nav {
+  font-size: 0.82rem;
+  text-transform: uppercase;
+}
+
+.lofi-mark {
+  margin: 0;
+  color: var(--red);
+  background: transparent;
+  font-family: var(--accent-font);
+  font-size: 0.82rem;
+  letter-spacing: 0;
+}
+
+main {
+  padding: 0 1.25rem 5rem;
+}
+
+.filter-section {
+  max-width: 66rem;
+  margin: 0 auto 2rem;
+}
+
+.tag-filters,
+.version-switcher {
+  display: flex;
+  flex-wrap: wrap;
+  justify-content: center;
+  gap: 0.55rem;
+}
+
+.tag-button,
+.version-button,
+.close-button {
+  min-height: 2.5rem;
+  border: 1px solid var(--line);
+  background: var(--paper);
+}
+
+.tag-button,
+.version-button {
+  padding: 0.55rem 0.8rem;
+  font-size: 0.78rem;
+  text-transform: uppercase;
+}
+
+.tag-button[aria-pressed="true"],
+.version-button[aria-pressed="true"] {
+  border-color: var(--red);
+  color: var(--red);
+}
+
+.gallery-section {
+  max-width: 74rem;
+  margin: 0 auto;
+}
+
+.gallery {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
+  gap: 1px;
+  border: 1px solid var(--line);
+  background: var(--line);
+}
+
+.gallery-card {
+  min-height: 24rem;
+  background: var(--paper);
+}
+
+.card-button {
+  display: grid;
+  grid-template-rows: minmax(12rem, 1fr) auto;
+  width: 100%;
+  min-height: 24rem;
+  padding: 0;
+  border: 0;
+  background: var(--paper);
+  text-align: left;
+}
+
+.card-button:hover .card-title,
+.card-button:focus-visible .card-title {
+  color: var(--red);
+}
+
+.card-button img {
+  width: 100%;
+  height: 100%;
+  min-height: 12rem;
+  object-fit: cover;
+  background:
+    linear-gradient(90deg, transparent 49%, rgba(0, 0, 0, 0.05) 50%, transparent 51%),
+    var(--soft);
+  border-bottom: 1px solid var(--line);
+  filter: grayscale(1);
+}
+
+.card-button img.is-missing {
+  border: 0;
+  color: transparent;
+}
+
+.card-content {
+  display: grid;
+  gap: 0.8rem;
+  padding: 1rem;
+}
+
+.card-title {
+  font-family: var(--title-font);
+  font-size: 1.8rem;
+  line-height: 1.1;
+}
+
+.card-description {
+  color: var(--muted);
+  font-size: 0.9rem;
+  line-height: 1.55;
+}
+
+.card-tags,
+.gallery-status,
+.transcript-note,
+.noscript-fallback,
+.text-fallback {
+  color: var(--muted);
+  font-size: 0.78rem;
+  line-height: 1.7;
+}
+
+.card-tags {
+  color: var(--red);
+  font-family: var(--accent-font);
+}
+
+.gallery-status {
+  margin: 1rem 0 0;
+  text-align: center;
+}
+
+.text-fallback {
+  display: none;
+  max-width: 38rem;
+  margin: 4rem auto 0;
+  border-top: 1px solid var(--line);
+  padding-top: 1.5rem;
+}
+
+.text-only .text-fallback {
+  display: block;
+}
+
+.video-overlay {
+  position: fixed;
+  inset: 0;
+  z-index: 10;
+  display: grid;
+  place-items: center;
+  padding: 1rem;
+  opacity: 0;
+  visibility: hidden;
+  pointer-events: none;
+  transition: opacity 260ms ease;
+}
+
+.video-overlay.is-visible {
+  opacity: 1;
+  visibility: visible;
+  pointer-events: auto;
+}
+
+.overlay-plane {
+  position: absolute;
+  inset: 0;
+  background: rgba(255, 255, 255, 0.96);
+}
+
+.video-dialog {
+  position: relative;
+  z-index: 1;
+  width: min(100%, 58rem);
+  max-height: calc(100vh - 2rem);
+  overflow: auto;
+  display: grid;
+  gap: 1rem;
+  justify-items: center;
+  padding: clamp(1rem, 4vw, 2.5rem);
+  background: var(--paper);
+  border: 1px solid var(--line);
+  text-align: center;
+  transform: translateY(0.5rem);
+  transition: transform 260ms ease;
+}
+
+.video-overlay.is-visible .video-dialog {
+  transform: translateY(0);
+}
+
+.close-button {
+  position: absolute;
+  right: 0.75rem;
+  top: 0.75rem;
+  width: 2.5rem;
+  padding: 0;
+  color: var(--red);
+  font-family: var(--accent-font);
+  font-size: 1rem;
+}
+
+.video-dialog h2 {
+  margin: 0;
+  font-family: var(--title-font);
+  font-size: clamp(2.4rem, 8vw, 5.5rem);
+  font-weight: 500;
+  line-height: 1;
+}
+
+.overlay-description {
+  max-width: 38rem;
+  margin: 0;
+  color: var(--muted);
+  line-height: 1.7;
+}
+
+.video-dialog video {
+  width: min(100%, 44rem);
+  aspect-ratio: 4 / 3;
+  background: var(--ink);
+}
+
+.noscript-fallback {
+  max-width: 38rem;
+  margin: 3rem auto;
+  padding: 1rem;
+  border: 1px solid var(--line);
+}
+
+@media (max-width: 640px) {
+  .site-title {
+    font-size: clamp(4rem, 22vw, 7rem);
+  }
+
+  .gallery-card,
+  .card-button {
+    min-height: 21rem;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  #intro-screen {
+    transition-duration: 80ms;
+  }
+
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    animation-duration: 0.001ms !important;
+    animation-iteration-count: 1 !important;
+  }
+}
